{
  "name": "POPKID-BOT",
  "description": "Popkid multi-device WhatsApp bot (Baileys)",
  "keywords": ["whatsapp", "bot", "baileys", "popkid", "nodejs"],
  "repository": "https://github.com/popkidultra/POPKID-BOT",
  "logo": "https://i.ibb.co/WNv1hWXT/file-000000001f5c81f4a38f20223ae695d1.png",
  "success_url": "/",
  "stack": "heroku-24",
  "buildpacks": [
    { "url": "heroku/nodejs" }
  ],
  "formation": {
    "web": {
      "quantity": 1,
      "size": "eco"
    }
  },
  "env": {
    "SESSION_ID": {
      "description": "Your POPKID session string, generated by pairing the bot once (looks like POPKID~xxxxxxxx...)",
      "required": true
    },
    "OCR_API_KEY": {
      "description": "Optional OCR.space API key for the .ocr command. Leave default if you don't have one.",
      "required": false
    }
  }
}
